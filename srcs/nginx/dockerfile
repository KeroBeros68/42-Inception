# Use Alpine as the base image
FROM alpine:3.20

# Install NGINX, OpenSSL (certificates), wget (healthcheck), and libcap (setcap)
RUN apk add --no-cache \
	nginx openssl wget libcap

# Create a dedicated non-root user/group for nginx
RUN addgroup -S nginxgroup && adduser -S nginxuser -G nginxgroup

# Copy the NGINX configuration file into the container
COPY conf/nginx.conf /etc/nginx/nginx.conf

# Copy the entrypoint script and make it executable
COPY tools/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Expose the internal port (default 443) dynamically injected at build time
ARG NGINX_PORT=443
EXPOSE ${NGINX_PORT}

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

CMD ["nginx", "-g", "daemon off;"]